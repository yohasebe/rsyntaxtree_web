#!/bin/bash
# Setup font aliases for RSyntaxTree on Ubuntu/Debian servers
# RSyntaxTree uses 'Noto Serif JP' / 'Noto Sans JP' in SVG font-family,
# but Ubuntu's package installs them as 'Noto Serif CJK JP' / 'Noto Sans CJK JP'.
# This script creates fontconfig aliases to bridge the naming gap.

set -e

CONF_FILE="/etc/fonts/conf.d/99-noto-cjk-jp-alias.conf"

# Install required fonts if not present
echo "Installing required fonts..."
sudo apt install -y fonts-noto-cjk fonts-noto-cjk-extra fonts-noto-core fonts-noto-mono fonts-wqy-zenhei

# Create fontconfig alias
echo "Creating fontconfig alias at ${CONF_FILE}..."
sudo tee "$CONF_FILE" > /dev/null << 'EOF'
<?xml version="1.0"?>
<!DOCTYPE fontconfig SYSTEM "fonts.dtd">
<fontconfig>
  <alias>
    <family>Noto Serif JP</family>
    <prefer><family>Noto Serif CJK JP</family></prefer>
  </alias>
  <alias>
    <family>Noto Sans JP</family>
    <prefer><family>Noto Sans CJK JP</family></prefer>
  </alias>
</fontconfig>
EOF

# Refresh font cache
echo "Refreshing font cache..."
sudo fc-cache -fv > /dev/null 2>&1

echo "Done. Font aliases configured successfully."
echo "Verify with: fc-match 'Noto Serif JP'"
